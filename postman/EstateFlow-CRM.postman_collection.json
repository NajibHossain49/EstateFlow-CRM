{
  "info": {
    "name": "EstateFlow CRM API",
    "_postman_id": "estateflow-crm-v1-collection",
    "description": "Postman collection for the EstateFlow CRM backend (Backend v1.0).\n\n- Base URL: `{{baseUrl}}` (default `http://localhost:3000/api/v1`)\n- Auth: JWT Bearer. Run **Auth > Login** first — the `accessToken` is captured automatically into a collection variable and applied to every protected request.\n- Chaining: **Create** requests store the new record id (`propertyId`, `clientId`, `leadId`, `visitId`, `mediaId`) so the Get/Update/Delete/Restore requests work without editing anything.\n\nImport this file into Postman via *Import > File*.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "userId", "value": "", "type": "string" },
    { "key": "propertyId", "value": "", "type": "string" },
    { "key": "clientId", "value": "", "type": "string" },
    { "key": "leadId", "value": "", "type": "string" },
    { "key": "visitId", "value": "", "type": "string" },
    { "key": "mediaId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane.doe@example.com\",\n  \"password\": \"Password123!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            },
            "description": "Register a new user. Password must contain uppercase, lowercase, number and a special character (min 8 chars). Rate limited to 3/min."
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res && res.data && res.data.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  console.log('accessToken saved to collection variables');",
                  "}",
                  "pm.test('Login returns an access token', function () {",
                  "  pm.expect(res.data && res.data.accessToken).to.be.a('string');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@estateflow.com\",\n  \"password\": \"Password123!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Login and receive a JWT. The token is saved to `{{accessToken}}` automatically. Rate limited to 5/min.\n\nSeeded logins (password `Password123!`): admin@estateflow.com, manager@estateflow.com, agent1@estateflow.com, agent2@estateflow.com."
          },
          "response": []
        }
      ]
    },

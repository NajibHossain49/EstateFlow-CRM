# Application
NODE_ENV=development
PORT=3000

# Database (used by the app and Prisma)
# When running the app locally against Docker Postgres, host is localhost.
DATABASE_URL="postgresql://postgres:123456@localhost:5432/estateflow?schema=public"

# PostgreSQL (used by docker-compose to provision the database container)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456
POSTGRES_DB=estateflow

# JWT
JWT_SECRET=super-secret-change-me-in-production
JWT_EXPIRES_IN=1d

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String     @id @default(uuid()) @db.Uuid
  name       String
  email      String     @unique
  password   String
  role       Role       @default(AGENT)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  clients    Client[]
  properties Property[]
  leads      Lead[]
  visits     Visit[]
  activities Activity[]
  media      Media[]

  @@map("users")
}

model Property {
  id           String         @id @default(uuid()) @db.Uuid
  title        String
  description  String
  price        Decimal        @db.Decimal(12, 2)
  location     String
  bedrooms     Int
  bathrooms    Int
  area         Int
  propertyType PropertyType
  status       PropertyStatus @default(AVAILABLE)
  createdBy    String         @db.Uuid
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?
  createdById  String?        @db.Uuid
  updatedById  String?        @db.Uuid
  deletedById  String?        @db.Uuid
  creator      User           @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  visits       Visit[]

  @@index([createdBy])
  @@index([deletedAt])
  @@index([status])
  @@index([propertyType])
  @@index([location])
  @@index([price])
  @@index([createdAt])
  @@index([status, propertyType])
  @@index([location, status])
  @@map("properties")
}

model Client {
  id                String   @id @default(uuid()) @db.Uuid
  name              String
  phone             String
  email             String?
  budget            Decimal  @db.Decimal(12, 2)
  preferredLocation String
  createdBy         String   @db.Uuid
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?
  createdById       String?  @db.Uuid
  updatedById       String?  @db.Uuid
  deletedById       String?  @db.Uuid
  creator           User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  visits            Visit[]

  @@index([createdBy])
  @@index([deletedAt])
  @@map("clients")
}

model Lead {
  id              String     @id @default(uuid()) @db.Uuid
  name            String
  phone           String
  email           String?
  source          String
  status          LeadStatus @default(NEW)
  notes           String?
  assignedAgentId String     @db.Uuid
  assignedAgent   User       @relation(fields: [assignedAgentId], references: [id], onDelete: Cascade)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?
  createdById     String?    @db.Uuid
  updatedById     String?    @db.Uuid
  deletedById     String?    @db.Uuid

  activities      Activity[]
  visits          Visit[]

  @@index([assignedAgentId])
  @@index([status])
  @@index([deletedAt])
  @@index([source])
  @@index([createdAt])
  @@index([status, assignedAgentId])
  @@map("leads")
}

model Visit {
  id         String      @id @default(uuid()) @db.Uuid
  clientId   String      @db.Uuid
  client     Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  propertyId String      @db.Uuid
  property   Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  agentId    String      @db.Uuid
  agent      User        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  leadId     String?     @db.Uuid
  lead       Lead?       @relation(fields: [leadId], references: [id], onDelete: SetNull)
  visitDate  DateTime
  status     VisitStatus @default(SCHEDULED)
  notes      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  deletedAt  DateTime?
  createdById String?    @db.Uuid
  updatedById String?    @db.Uuid
  deletedById String?    @db.Uuid

  @@index([clientId])
  @@index([propertyId])
  @@index([agentId])
  @@index([leadId])
  @@index([status])
  @@index([deletedAt])
  @@index([visitDate])
  @@map("visits")
}

model Activity {
  id          String       @id @default(uuid()) @db.Uuid
  type        ActivityType
  description String
  leadId      String?      @db.Uuid
  lead        Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdBy   String       @db.Uuid
  creator     User         @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())
  deletedAt   DateTime?
  createdById String?      @db.Uuid
  updatedById String?      @db.Uuid
  deletedById String?      @db.Uuid

  @@index([leadId])
  @@index([createdBy])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([createdById])
  @@map("activities")
}

model Media {
  id           String           @id @default(uuid()) @db.Uuid
  url          String
  publicId     String           @unique
  originalName String
  mimeType     String
  size         Int
  width        Int?
  height       Int?
  // Polymorphic association: entityType + entityId link media to any resource
  // (currently PROPERTY) without a hard FK, keeping the module extensible.
  entityType   MediaEntityType?
  entityId     String?          @db.Uuid
  order        Int              @default(0)
  createdBy    String           @db.Uuid
  creator      User             @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt    DateTime         @default(now())
  deletedAt    DateTime?
  createdById  String?          @db.Uuid
  updatedById  String?          @db.Uuid
  deletedById  String?          @db.Uuid

  @@index([entityType, entityId])
  @@index([createdBy])
  @@index([deletedAt])
  @@map("media")
}

enum MediaEntityType {
  PROPERTY
}

enum Role {
  ADMIN
  MANAGER
  AGENT
}

enum PropertyType {
  HOUSE
  APARTMENT
  LAND
  COMMERCIAL
}

enum PropertyStatus {
  AVAILABLE
  SOLD
  RENTED
}

enum LeadStatus {
  NEW
  CONTACTED
  INTERESTED
  VISIT_SCHEDULED
  NEGOTIATION
  WON
  LOST
}

enum VisitStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum ActivityType {
  LEAD_CREATED
  LEAD_UPDATED
  STATUS_CHANGED
  VISIT_CREATED
  VISIT_COMPLETED
  NOTE_ADDED
}

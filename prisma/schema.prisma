generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String     @id @default(uuid()) @db.Uuid
  name       String
  email      String     @unique
  password   String
  role       Role       @default(AGENT)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  clients    Client[]
  properties Property[]
  leads      Lead[]
  visits     Visit[]

  @@map("users")
}

model Property {
  id           String         @id @default(uuid()) @db.Uuid
  title        String
  description  String
  price        Decimal        @db.Decimal(12, 2)
  location     String
  bedrooms     Int
  bathrooms    Int
  area         Int
  propertyType PropertyType
  status       PropertyStatus @default(AVAILABLE)
  createdBy    String         @db.Uuid
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  creator      User           @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  visits       Visit[]

  @@index([createdBy])
  @@map("properties")
}

model Client {
  id                String   @id @default(uuid()) @db.Uuid
  name              String
  phone             String
  email             String?
  budget            Decimal  @db.Decimal(12, 2)
  preferredLocation String
  createdBy         String   @db.Uuid
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  creator           User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  visits            Visit[]

  @@index([createdBy])
  @@map("clients")
}

model Lead {
  id              String     @id @default(uuid()) @db.Uuid
  name            String
  phone           String
  email           String?
  source          String
  status          LeadStatus @default(NEW)
  notes           String?
  assignedAgentId String     @db.Uuid
  assignedAgent   User       @relation(fields: [assignedAgentId], references: [id], onDelete: Cascade)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([assignedAgentId])
  @@index([status])
  @@map("leads")
}

model Visit {
  id         String      @id @default(uuid()) @db.Uuid
  clientId   String      @db.Uuid
  client     Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  propertyId String      @db.Uuid
  property   Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  agentId    String      @db.Uuid
  agent      User        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  visitDate  DateTime
  status     VisitStatus @default(SCHEDULED)
  notes      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([clientId])
  @@index([propertyId])
  @@index([agentId])
  @@index([status])
  @@map("visits")
}

enum Role {
  ADMIN
  AGENT
}

enum PropertyType {
  HOUSE
  APARTMENT
  LAND
  COMMERCIAL
}

enum PropertyStatus {
  AVAILABLE
  SOLD
  RENTED
}

enum LeadStatus {
  NEW
  CONTACTED
  INTERESTED
  VISIT_SCHEDULED
  NEGOTIATION
  WON
  LOST
}

enum VisitStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}
